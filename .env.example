# AirGradient API token (from https://app.airgradient.com)
AIR_GRADIENT_TOKEN=your_airgradient_token_here

# InfluxDB credentials — change before first run
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change_me_strong_password
INFLUXDB_TOKEN=change_me_strong_token
INFLUXDB_ORG=airgradient
INFLUXDB_BUCKET=air_data

# Polling interval in seconds
POLL_INTERVAL=60
